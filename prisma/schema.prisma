// // Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  TUTOR
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

//////////////////////
// AUTH MODELS
//////////////////////

model User {
  id            String   @id
  name          String
  email         String
  role          UserRole @default(USER)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  UserStatus    Boolean  @default(true) //BAN OR UNBAND

  // Auth relations
  sessions Session[]
  accounts Account[]

  // SkillBridge relations
  // tutorProfile  TutorProfile?
  bookings      Booking[]      @relation("StudentBookings")
  reviews       Review[]       @relation("StudentReviews")
  tutorProfiles TutorProfile[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//////////////////////
// SKILLBRIDGE MODELS
//////////////////////

model TutorProfile {
  id            String   @id @default(uuid())
  userId        String   @default("")
  bio           String?
  hourlyRate    Float
  averageRating Float    @default(0)
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories   Category[]
  bookings     Booking[]
  reviews      Review[]
  availability AvailabilitySlot[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  tutors TutorProfile[]
}

model Booking {
  id        String @id @default(uuid())
  studentId String
  tutorId   String
  slotId    String // remove @unique to allow multiple students to book same slot

  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())

  student User             @relation("StudentBookings", fields: [studentId], references: [id])
  tutor   TutorProfile     @relation(fields: [tutorId], references: [id])
  slot    AvailabilitySlot @relation(fields: [slotId], references: [id])


}

model AvailabilitySlot {
  id        String   @id @default(uuid())
  tutorId   String
  startTime DateTime
  endTime   DateTime
  subject   String
  tag       String[]
  isBooked  Boolean  @default(false)

  tutor    TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  bookings Booking[] // virtual relation; multiple bookings possible
  reviews  Review[]
}

model Review {
  id        String   @id @default(uuid())
 
  studentId String
  slotId    String   // ✅ use consistent naming (camelCase)
  tutorId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())


  student User         @relation("StudentReviews", fields: [studentId], references: [id])
  tutor   TutorProfile @relation(fields: [tutorId], references: [id])

  // ✅ Proper relation
  availabilitySlot AvailabilitySlot @relation(fields: [slotId], references: [id])
}